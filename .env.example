# Base URL of the Moodlr Task Manager API (required).
# For production use: https://tasks.moodlr.com
# For local dev: http://localhost:3000
MOODLR_API_URL="http://localhost:3000"

# Personal access token generated at /api/profile/api-keys.
# Starts with moodlr_ and is shown only once on creation.
MOODLR_API_KEY="moodlr_replace_me"
